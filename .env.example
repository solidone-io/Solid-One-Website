# API server port (default 3001)
API_PORT=3001

# Admin panel password — used at /admin1855
ADMIN_PASSWORD=change-this-password

# Vercel Blob (required on Vercel for blog, forms, and image uploads)
# Create in Vercel: Project → Storage → Blob → Connect
BLOB_READ_WRITE_TOKEN=

# Google OAuth — required for /download page sign-in
# Create at https://console.cloud.google.com/apis/credentials (OAuth 2.0 Web client)
# Authorized JavaScript origins: http://localhost:5173 and your production URL
VITE_GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_ID=

# Optional: separate secret for download session tokens (defaults to ADMIN_PASSWORD)
DOWNLOAD_JWT_SECRET=

# Local dev only: set to 1 if sign-in fails with SSL/certificate errors (antivirus HTTPS scan). Never on Vercel.
DOWNLOAD_DEV_INSECURE_TLS=
