# API server port for local dev (default 3001)
API_PORT=3001

# Admin panel password — used at /admin1855
ADMIN_PASSWORD=change-this-password

# MongoDB Atlas — same cluster as auth-api (Railway). Required on Vercel instead of Blob.
# Copy MONGODB_URI from auth-api Railway env or MongoDB Atlas → Connect.
MONGODB_URI=
MONGODB_DB=solidone

# Optional: only if mongodb+srv fails on Windows dev
# MONGODB_URI_STANDARD=

# Legacy — not needed when MONGODB_URI is set
# BLOB_READ_WRITE_TOKEN=

# Google OAuth — required for /download page sign-in
# Create at https://console.cloud.google.com/apis/credentials (OAuth 2.0 Web client)
# Authorized JavaScript origins: http://localhost:5173 and https://solidone.io
VITE_GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_ID=

# Optional: separate secret for download session tokens (defaults to ADMIN_PASSWORD)
DOWNLOAD_JWT_SECRET=

# Local dev only: set to 1 if sign-in fails with SSL/certificate errors (antivirus HTTPS scan). Never on Vercel.
DOWNLOAD_DEV_INSECURE_TLS=

# APK release — file at public/releases/solid-one.apk (served via CDN on Vercel)
# APK_PATH=
# APK_VERSION_CODE=1
# APK_VERSION_NAME=1.0.3
